FROM rust:1-bookworm

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/usr/local/cargo/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      build-essential \
      file \
      libayatana-appindicator3-dev \
      librsvg2-dev \
      libssl-dev \
      libgtk-3-dev \
      libwebkit2gtk-4.1-dev \
      nodejs \
      npm \
      patchelf \
      pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
