{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "muz-test",
  "version": "0.2.3",
  "identifier": "cn.aidl.questionexam",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "muz-test",
        "width": 1360,
        "height": 900,
        "minWidth": 1050,
        "minHeight": 700,
        "backgroundColor": "#f3f6fc"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/question-bank/manifest.json": "question-bank/manifest.json",
      "../resources/question-bank/ai": "question-bank/ai",
      "../resources/question-bank/data-structure": "question-bank/data-structure",
      "../resources/question-bank/intelligent-sensing-control": "question-bank/intelligent-sensing-control",
      "../resources/question-bank/ds-assets": "question-bank/ds-assets"
    }
  }
}
