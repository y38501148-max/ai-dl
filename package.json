{
  "name": "ai-question-exam",
  "version": "0.1.2",
  "description": "人工智能导论题库桌面练习与考试应用",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "import:questions": "node scripts/import-question-bank.mjs",
    "typecheck": "vue-tsc --noEmit",
    "build:web": "npm run typecheck && vite build",
    "build": "npm run build:web && electron-builder",
    "pack:mac": "npm run build:web && electron-builder --mac --arm64",
    "pack:mac:universal": "npm run build:web && electron-builder --mac --universal",
    "pack:win": "npm run build:web && electron-builder --win --x64"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.7.3",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "cn.aidl.questionexam",
    "productName": "人工智能导论题库",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/question-bank.zip",
        "to": "question-bank.zip"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
